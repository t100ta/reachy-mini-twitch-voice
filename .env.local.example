# Twitch
TWITCH_CHANNEL=tom_t100ta
# IRC接続用。先頭に oauth: を付ける（validate APIは生tokenを使う）
TWITCH_OAUTH_TOKEN=oauth:YOUR_ACCESS_TOKEN
TWITCH_NICK=tom_t100ta

# Conversation (OpenAI Realtime-like flow)
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-mini
CONVERSATION_ENGINE=realtime
CONVERSATION_INPUT_MODE=twitch
TWITCH_MESSAGE_CONTEXT_WINDOW=30
OPENAI_TIMEOUT_SEC=10.0
PERSONA_NAME=NUVA
PERSONA_NAME_KANA=ヌーバ
OPERATOR_NAME=にかなとむ(tom_t100ta)
PERSONA_STYLE=親しみを保ちつつ、常に適度に礼儀正しく
# 空なら src同梱の既定プロンプトを使用。外部ファイルで上書きしたい時だけ指定
SYSTEM_PROMPT_FILE=
OPERATOR_USERNAMES=tom_t100ta,にかなとむ
PROFILE_STORAGE_DIR=~/.config/reachy-mini-twitch-voice/profiles
ACTIVE_PROFILE=

# Reachy runtime
REACHY_EXECUTION_HOST=on_reachy
REACHY_CONNECTION_MODE=auto
REACHY_TTS_ENGINE=openai-tts
REACHY_TTS_LANG=ja
REACHY_TTS_OPENAI_MODEL=gpt-4o-mini-tts
REACHY_TTS_OPENAI_VOICE=alloy
REACHY_TTS_OPENAI_FORMAT=wav
REACHY_TTS_OPENAI_SPEED=1.15
REACHY_GESTURE_ENABLED=true
REACHY_SPEECH_MOTION_ENABLED=true
REACHY_AUDIO_VOLUME=
REACHY_HEALTHCHECK_URL=http://localhost:8000/api/state/full
REACHY_CONNECT_TIMEOUT_SEC=45.0
REACHY_CONNECT_RETRIES=3
REACHY_CONNECT_RETRY_INTERVAL_SEC=3.0
IDLE_USE_DOA=false

# Web console
WEB_CONSOLE_ENABLED=true
WEB_CONSOLE_HOST=0.0.0.0
WEB_CONSOLE_PORT=7860

# Pipeline tuning
MAX_CHARS=140
SPAM_WINDOW_SEC=5
MESSAGE_TIMEOUT_MS=15000
RECONNECT_MAX_SEC=30
IDLE_MOTION_ENABLED=true
IDLE_INTERVAL_SEC=3
MAX_QUEUE_SIZE=100
MAX_QUEUE_WAIT_MS=60000
QUEUE_DROP_POLICY=drop_oldest
