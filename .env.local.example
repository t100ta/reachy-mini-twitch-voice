# Twitch
TWITCH_CHANNEL=tom_t100ta
# IRC接続用。先頭に oauth: を付ける（validate APIは生tokenを使う）
TWITCH_OAUTH_TOKEN=oauth:YOUR_ACCESS_TOKEN
TWITCH_NICK=tom_t100ta

# Conversation engine (hermes=メイン, realtime/http=切り戻し用)
# Hermes Agent (LAN上のOpenAI互換サーバー) をメインエンジンとして使用する
CONVERSATION_ENGINE=hermes
CONVERSATION_INPUT_MODE=twitch
# OpenAI (切り戻し/フォールバック用。hermes使用時は不要)
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-mini
TWITCH_MESSAGE_CONTEXT_WINDOW=30
OPENAI_TIMEOUT_SEC=10.0
PERSONA_NAME=NUVA
PERSONA_NAME_KANA=ヌーバ
OPERATOR_NAME=にかなとむ(tom_t100ta)
PERSONA_STYLE=親しみを保ちつつ、常に適度に礼儀正しく
# 空なら src同梱の既定プロンプトを使用。外部ファイルで上書きしたい時だけ指定
SYSTEM_PROMPT_FILE=
OPERATOR_USERNAMES=tom_t100ta,にかなとむ
PROFILE_STORAGE_DIR=~/.config/reachy-mini-twitch-voice/profiles
ACTIVE_PROFILE=
# ネイティブ function calling（robot_action / get_twitch_info）を有効化
ENABLE_TOOLS=true
# Web検索ツールを有効化（要: OPENAI_REALTIME_MODEL=gpt-4o-mini-search-preview 等の search 対応モデル）
# ENABLE_WEB_SEARCH=false

# Reachy runtime
REACHY_EXECUTION_HOST=on_reachy
REACHY_CONNECTION_MODE=auto
REACHY_TTS_ENGINE=openai-tts
REACHY_TTS_LANG=ja
REACHY_TTS_OPENAI_MODEL=gpt-4o-mini-tts
REACHY_TTS_OPENAI_VOICE=alloy
REACHY_TTS_OPENAI_FORMAT=wav
REACHY_TTS_OPENAI_SPEED=1.15
REACHY_GESTURE_ENABLED=true
REACHY_SPEECH_MOTION_ENABLED=true
REACHY_AUDIO_VOLUME=
REACHY_HEALTHCHECK_URL=http://localhost:8000/api/state/full
REACHY_CONNECT_TIMEOUT_SEC=45.0
REACHY_CONNECT_RETRIES=3
REACHY_CONNECT_RETRY_INTERVAL_SEC=3.0
IDLE_USE_DOA=false

# Hermes Agent (OpenAI-compatible Chat Completions backend) — メインエンジン
# LAN上の Hermes Agent API Server を指定する。config.pyのデフォルト(127.0.0.1:8642)は開発用。
HERMES_BASE_URL=http://192.168.4.30:8643/v1
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT_SEC=12.0
HERMES_STREAM=false
HERMES_USE_RESPONSES_API=false
HERMES_CONVERSATION_PREFIX=reachy-twitch
HERMES_RETRY_COUNT=1
# Hermes 専用 system prompt の上書き（空なら src 同梱の hermes_twitch_system_ja.txt を使用）
HERMES_SYSTEM_PROMPT_FILE=

# Viewer memory (preferred name + light notes per Twitch viewer)
VIEWER_MEMORY_ENABLED=true
VIEWER_MEMORY_DB_PATH=~/.config/reachy-mini-twitch-voice/viewer_memory.sqlite3
VIEWER_MEMORY_MAX_NOTES=8
VIEWER_MEMORY_SAVE_SOURCE_MESSAGE=false

# Stream journal (配信日記: 配信終了時にHermesで要約→次回起動時のプロンプトに注入)
STREAM_JOURNAL_ENABLED=true
STREAM_JOURNAL_DB_PATH=~/.config/reachy-mini-twitch-voice/viewer_memory.sqlite3
STREAM_JOURNAL_INJECT_RECENT_COUNT=2
STREAM_JOURNAL_SUMMARY_TIMEOUT_SEC=20.0
STREAM_JOURNAL_MIN_TURNS_FOR_SUMMARY=3

# Web console
WEB_CONSOLE_ENABLED=true
WEB_CONSOLE_HOST=0.0.0.0
WEB_CONSOLE_PORT=7860

# Pipeline tuning
MAX_CHARS=140
SPAM_WINDOW_SEC=5
MESSAGE_TIMEOUT_MS=15000
RECONNECT_MAX_SEC=30
IDLE_MOTION_ENABLED=true
IDLE_INTERVAL_SEC=3
MAX_QUEUE_SIZE=100
MAX_QUEUE_WAIT_MS=60000
QUEUE_DROP_POLICY=drop_oldest
